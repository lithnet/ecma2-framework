<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    A scoped nuget.config for the package-test consumer. It adds the repo's local package output
    (artifacts\nupkg) as a source so this project restores the freshly-produced Lithnet.Ecma2Framework package,
    proving a clean consumer can build the host exe + shim from the package alone. nuget.org is still available
    for the consumer's own transitive dependencies (Microsoft.Extensions.*, etc.).
  -->
  <packageSources>
    <add key="ecma2-local" value="..\..\artifacts\nupkg" />
  </packageSources>
</configuration>
